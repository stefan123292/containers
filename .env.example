# Resend (https://resend.com) — required for quote & contact emails
RESEND_API_KEY=

# Sender (must be verified in Resend; onboarding@resend.dev works for tests)
EMAIL_FROM=BoXpert <onboarding@resend.dev>

# Where business mail arrives
EMAIL_TO=contact@boxpert.ro

# Send confirmation copy to the user after quote request (true/false)
EMAIL_SEND_USER_CONFIRMATION=true
